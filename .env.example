# Kopiere diese Datei zu ".env" und trag deine Keys ein.
OPENAI_API_KEY=sk-...dein-key-hier...

# Musik (gratis, legal): Jamendo Client-ID — kostenlos unter
# https://developer.jamendo.com  → App registrieren → "Client ID" kopieren.
JAMENDO_CLIENT_ID=

# Optional:
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
# PORT=8771
